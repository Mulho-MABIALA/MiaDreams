APP_NAME="MIA DREAMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mia-dreams.onrender.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=pgsql
DATABASE_URL=

CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120

ADMIN_NAME="Admin MiaDreams"
ADMIN_EMAIL=
ADMIN_PASSWORD=

MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

BROADCAST_DRIVER=log

VITE_APP_NAME="${APP_NAME}"
