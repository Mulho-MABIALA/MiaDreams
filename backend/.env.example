# ────────────────────────────────────────────
#  MIA DREAMS & CO — Variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs
# ────────────────────────────────────────────

NODE_ENV=production
PORT=5000

# MongoDB Atlas (mongodb.com → Create cluster → Connect)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/MiaDreamsdb

# URL du frontend Vercel (SANS slash final)
FRONTEND_URL=https://mia-dreams.vercel.app

# Clé secrète JWT — générez une chaîne aléatoire longue
JWT_SECRET=remplacez-par-une-cle-secrete-aleatoire-de-64-caracteres

# Webhook GitHub auto-deploy (générez un secret aléatoire et mettez-le AUSSI sur GitHub)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GITHUB_WEBHOOK_SECRET=remplacez-par-un-secret-aleatoire

# Compte administrateur créé au 1er démarrage
ADMIN_NAME=Admin MiaDreams
ADMIN_EMAIL=admin@miadreams.com
ADMIN_PASSWORD=MotDePasseSecurise2024!

# SMTP (Gmail : activez "App Password" dans votre compte Google)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=votre@gmail.com
MAIL_PASS=xxxx-xxxx-xxxx-xxxx
MAIL_FROM=votre@gmail.com

# URL publique du backend Render (SANS slash final)
BACKEND_URL=https://mia-dreams.onrender.com

# Paiements (optionnel)
WAVE_API_KEY=
ORANGE_MONEY_TOKEN=
ORANGE_MONEY_MERCHANT_KEY=
FREE_MONEY_API_KEY=

# ── Notifications WhatsApp (CallMeBot — gratuit) ──────────────────────────────
# 1. Envoie "I allow callmebot to send me messages" au +34 644 69 73 99 sur WhatsApp
# 2. Tu recevras ton apikey par WhatsApp
# 3. Numéro avec indicatif pays, SANS le + (ex: 2250700000000)
WHATSAPP_PHONE=
WHATSAPP_APIKEY=
